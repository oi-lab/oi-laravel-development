{
    "name": "oi-lab/oi-laravel-development",
    "description": "A Laravel package providing essential development and initialization commands",
    "keywords": [
        "laravel",
        "development",
        "artisan",
        "commands",
        "dev-tools"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Olivier Lacombe",
            "email": "contact@olacombe.com",
            "homepage": "https://www.olacombe.com"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "laravel/prompts": "^0.1"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "OiLab\\OiLaravelDevelopment\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OiLab\\OiLaravelDevelopment\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OiLab\\OiLaravelDevelopment\\OiLaravelDevelopmentServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
